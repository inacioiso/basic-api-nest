generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PROFESSOR
  ALUNO
  ADMIN
}

enum Concept {
  PESSIMO
  RUIM
  REGULAR
  BOM
  EXCELENTE
}

model User {
  id        String @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  disciplines Discipline[] @relation("ProfessorDisciplines")
  enrollments Enrollment[]
}

model Discipline {
  id          String   @id @default(uuid())
  name        String
  professorId String
  createdAt   DateTime @default(now())

  professor   User        @relation("ProfessorDisciplines", fields: [professorId], references: [id])
  classes     Classroom[]
  criteria    Criteria[]
}

model Classroom {
  id            String   @id @default(uuid())
  name          String
  disciplineId  String
  createdAt     DateTime @default(now())

  discipline   Discipline  @relation(fields: [disciplineId], references: [id])
  enrollments  Enrollment[]
}

model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  classId    String

  finalScore Float?
  concept    Concept?

  student    User       @relation(fields: [studentId], references: [id])
  classroom  Classroom  @relation(fields: [classId], references: [id])
  evaluations Evaluation[]

  @@unique([studentId, classId])
}

model Criteria {
  id           String @id @default(uuid())
  name         String
  disciplineId String

  discipline   Discipline   @relation(fields: [disciplineId], references: [id])
  subCriteria  SubCriteria[]
}

model SubCriteria {
  id         String  @id @default(uuid())
  name       String
  weight     Float
  criteriaId String

  criteria   Criteria     @relation(fields: [criteriaId], references: [id])
  evaluations Evaluation[]
}

model Evaluation {
  id            String  @id @default(uuid())
  enrollmentId  String
  subCriteriaId String
  score         Float

  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id])
  subCriteria  SubCriteria @relation(fields: [subCriteriaId], references: [id])

  @@unique([enrollmentId, subCriteriaId])
}